{
  "name": "@bitsentry-ce/superterminal",
  "version": "0.1.0",
  "description": "SuperTerminal Community Edition - SSH runbooks for on-call engineers",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "setup": "pnpm install && pnpm --dir packages/electron-trpc install",
    "changelog": "git-cliff -c cliff.toml",
    "changelog:desktop": "git-cliff -c cliff.toml --tag-pattern '^desktop-v[0-9].*'",
    "changelog:desktop:unreleased": "git-cliff -c cliff.toml --tag-pattern '^desktop-v[0-9].*' --unreleased",
    "build": "pnpm run build:packages && pnpm run desktop:build",
    "lint": "node scripts/eslint/ts7-unavailable.mjs && pnpm --dir packages/electron-trpc run lint",
    "lint:fix": "pnpm --filter @bitsentry-ce/desktop lint:fix && pnpm --filter @bitsentry/plugin-sdk lint:fix && pnpm --filter @bitsentry-ce/core lint:fix && pnpm --filter './packages/plugins/*' lint:fix && pnpm --filter @bitsentry-ce/components lint:fix && pnpm --filter @bitsentry-ce/coding-agents lint:fix && pnpm --filter @bitsentry-ce/desktop-cli lint:fix && pnpm --filter @bitsentry-ce/i18n lint:fix && pnpm --dir packages/electron-trpc run lint:fix",
    "format": "pnpm --dir packages/electron-trpc run lint:fix",
    "format:check": "pnpm --dir packages/electron-trpc run lint",
    "build:packages": "pnpm run plugins:build && pnpm --filter @bitsentry-ce/i18n build && pnpm --filter @bitsentry-ce/components build && pnpm --filter @bitsentry-ce/coding-agents build && pnpm --filter @bitsentry-ce/desktop-cli build",
    "plugin-sdk:build": "pnpm --filter @bitsentry/plugin-sdk build",
    "core:build": "pnpm --filter @bitsentry/plugin-sdk build && pnpm --filter @bitsentry-ce/core build",
    "i18n:build": "pnpm --filter @bitsentry-ce/i18n build",
    "components:build": "pnpm --filter @bitsentry-ce/components build",
    "plugins:build": "pnpm --filter @bitsentry/plugin-sdk build && pnpm --filter @bitsentry-ce/core build && pnpm --filter './packages/plugins/*' build && pnpm run plugins:build-artifacts",
    "plugins:build-artifacts": "node scripts/plugins/build-artifacts.mjs",
    "plugins:lint": "pnpm --filter './packages/plugins/*' lint",
    "plugins:publish-artifacts": "pnpm run plugins:build && node scripts/plugins/publish-artifacts.mjs",
    "plugins:test": "pnpm --filter './packages/plugins/*' test",
    "core:test": "pnpm --filter @bitsentry-ce/core test",
    "desktop-cli:test": "pnpm --filter @bitsentry-ce/desktop-cli test",
    "plugin-runtime:test": "pnpm --filter @bitsentry-ce/core test -- tests/plugin-runtime.spec.ts",
    "plugin-install:test": "pnpm --filter @bitsentry-ce/core test -- tests/plugin-artifact-install.spec.ts && pnpm --filter @bitsentry-ce/desktop-cli test -- tests/plugin-cli.spec.ts",
    "plugin-system:test": "pnpm run plugins:build && pnpm run plugin-runtime:test && pnpm run plugins:test && pnpm run plugin-install:test",
    "coding-agents:build": "pnpm --filter @bitsentry-ce/coding-agents build",
    "electron-trpc:build": "pnpm --filter electron-trpc run build",
    "desktop:dev": "pnpm --filter @bitsentry-ce/desktop dev",
    "desktop:clean-macos-dev": "pnpm --filter @bitsentry-ce/desktop clean-macos-dev",
    "desktop:build": "pnpm --filter @bitsentry-ce/desktop build",
    "desktop:start": "pnpm --filter @bitsentry-ce/desktop start",
    "desktop:package": "pnpm run build:packages && pnpm --filter @bitsentry-ce/desktop package",
    "desktop:test": "pnpm --filter @bitsentry-ce/desktop test",
    "desktop:test:plugin-installation": "pnpm --filter @bitsentry-ce/desktop test:plugin-installation",
    "desktop:test:cli": "pnpm --filter @bitsentry-ce/desktop test:cli-smoke",
    "desktop:test:cli:stress": "pnpm --filter @bitsentry-ce/desktop test:cli-stress",
    "desktop:test:cli:packaged": "pnpm --filter @bitsentry-ce/desktop test:cli-packaged-smoke",
    "desktop:test:cli:packaged:stress": "pnpm --filter @bitsentry-ce/desktop test:cli-packaged-stress",
    "desktop:test:contracts": "pnpm --filter @bitsentry-ce/desktop test:contracts",
    "desktop:quality": "pnpm --dir packages/electron-trpc --filter electron-trpc build && pnpm run desktop:typecheck && pnpm run desktop:typecheck:test && pnpm run desktop:test:contracts && pnpm run plugin-system:test && pnpm run desktop:test && pnpm run desktop:build",
    "desktop:quality:smoke": "xvfb-run -a pnpm run desktop:test:smoke",
    "desktop:test:smoke": "pnpm --filter @bitsentry-ce/desktop test:smoke",
    "desktop:typecheck": "pnpm --filter @bitsentry-ce/desktop typecheck",
    "desktop:typecheck:test": "pnpm --filter @bitsentry-ce/desktop typecheck:test",
    "desktop:typecheck:contract": "pnpm --filter @bitsentry-ce/desktop run typecheck:contract",
    "desktop:build:notarize-hook": "pnpm --filter @bitsentry-ce/desktop run build:notarize-hook",
    "desktop:install:mac:arm64:dev": "pnpm --filter @bitsentry-ce/desktop run install:mac:arm64:dev",
    "desktop:package:mac": "pnpm --filter @bitsentry-ce/desktop run package:mac",
    "desktop:package:mac:arm64": "pnpm --filter @bitsentry-ce/desktop run package:mac:arm64",
    "desktop:package:mac:arm64:install": "pnpm --filter @bitsentry-ce/desktop run package:mac:arm64:install",
    "desktop:package:mac:x64": "pnpm --filter @bitsentry-ce/desktop run package:mac:x64",
    "desktop:package:linux": "pnpm --filter @bitsentry-ce/desktop run package:linux",
    "desktop:package:win": "pnpm --filter @bitsentry-ce/desktop run package:win",
    "desktop:package:publish": "pnpm --filter @bitsentry-ce/desktop run package:publish",
    "desktop:predev": "pnpm --filter @bitsentry-ce/desktop run predev",
    "desktop:verify:mac-app": "pnpm --filter @bitsentry-ce/desktop run verify:mac-app"
  },
  "author": "BitSentry Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "0.27.7",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^68.0.0",
    "git-cliff": "^2.13.1",
    "globals": "^17.3.0",
    "typescript": "7.0.2",
    "typescript-eslint": "^8.63.0"
  }
}
