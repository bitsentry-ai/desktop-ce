{
  "name": "@bitsentry/plugin-sdk",
  "version": "0.1.0",
  "description": "SDK contracts and validation schemas for BitSentry desktop plugins.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "keywords": [
    "bitsentry",
    "superterminal",
    "plugin",
    "sdk",
    "zod"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitsentry-ai/plugin-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/bitsentry-ai/plugin-sdk/issues"
  },
  "homepage": "https://github.com/bitsentry-ai/plugin-sdk#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
